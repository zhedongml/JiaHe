<?xml version="1.0"?>
<root main_tree_to_execute="BehaviorTree">
 <BehaviorTree ID="BehaviorTree">
  <!-- Add nodes here -->
  <Sequence name="Sequence">
   <!-- System Init -->
   <Action name="System_Date" ID="System_Date" date_key="cur_data"/>
   <Action name="System_DateTime" ID="System_DateTime" date_time_key="cur_datatime"/>
   <!-- <Action name="System_InputTips" ID="System_InputTips" tip="Please input operator initials !" text_key="{name}"/> -->
   <!--alignment process-->
   <Action name="IQ_SetEyeboxList" ID="IQ_SetEyeboxList" eyeboxlist="1,3,5" key="eyeboxids"/>
   <Action name="IQ_Metrics_CreateDBTable" ID="IQ_Metrics_CreateDBTable"/>
   <For name="For" traverse_params="1">
    <Sequence name="Sequence">
     <Action name="System_GetForNodeValue1" ID="System_GetForNodeValue1" value_key="cur_wafer_dutID"/>
     <Action name="System_InputTips" ID="System_InputTips" tip="Please enter dut serial number !" param="serial_number" is_lable_visual="1" text_key="dutid"/>
     <!--Define Csv File and dut folder path-->
     <Action name="IQ_Metrics_CreateDutResultFile" ID="IQ_Metrics_CreateDutResultFile" root_dir="E:\SAT_GRR\{cur_data}_MetricsTest" dut_seq="COT_{dutid}_{cur_datatime}_WG_IQT-MTF-1_OQC" csvname="{dutid}_{cur_datatime}_metrics_{eyeboxids}" all_csvname="metrics_{eyeboxids}_all" dut_folder="dut_measure_folder"/>
     <For name="For" traverse_params="{eyeboxids}">
      <Sequence name="Sequence">
       <Action name="System_GetForNodeValue1" ID="System_GetForNodeValue1" value_key="cur_eb"/>
       <Parallel name="Parallel">
        <Action name="IQ_Metrics_CreateEyeboxResultFile" ID="IQ_Metrics_CreateEyeboxResultFile" root_dir="{dut_measure_folder}\{dutid}_EB{cur_eb}_{cur_datatime}"/>
       </Parallel>
      </Sequence>
     </For>
    </Sequence>
   </For>
   <!-- IQ Metrics Module -->
   <Action name="IQ_Metrics_ExportToCSV" ID="IQ_Metrics_ExportToCSV"/>
  </Sequence>
 </BehaviorTree>
</root>
